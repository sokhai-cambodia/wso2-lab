# Root .env — credentials passed to the backend Docker container.
# Copy to .env and fill in values after registering apps in WSO2 IS and APIM.

# WSO2 IS: OAuth app registered at https://localhost:9444/console
# Callback URL to register: http://localhost:3000/callback
WSO2_IS_CLIENT_ID=
WSO2_IS_CLIENT_SECRET=
WSO2_IS_PUBLIC_URL=https://localhost:9444
GITHUB_IDP_NAME=github

# PostgreSQL — defaults match docker-compose.yml; override if needed
POSTGRES_PORT=5433
POSTGRES_USER=wso2
POSTGRES_PASSWORD=wso2123
POSTGRES_DB=wso2db
