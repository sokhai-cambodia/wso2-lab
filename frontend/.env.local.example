# Copy to .env.local — only these two vars are needed by the Next.js frontend.
# All WSO2 credentials live in the root .env (used by the backend container).

# Backend API (FastAPI — handles auth flow and WSO2 credentials)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# APIM Gateway — called directly from the browser for API testing
NEXT_PUBLIC_APIM_GATEWAY_URL=https://localhost:8243
