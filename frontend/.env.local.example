# Copy this file to .env.local and fill in the values.
# Steps to get these values are in PRACTICE.md → Step 0.5

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-any-random-32-char-string

# WSO2 IS 7.0.0 OIDC App (register in IS Console → Applications → New Application)
# Redirect URI to register: http://localhost:3000/api/auth/callback/wso2is
WSO2_IS_URL=https://localhost:9444
WSO2_IS_CLIENT_ID=
WSO2_IS_CLIENT_SECRET=

# WSO2 APIM 4.3.0 (get from DevPortal → Applications → DefaultApplication → Production Keys)
WSO2_APIM_URL=https://localhost:9443
WSO2_APIM_GATEWAY=https://localhost:8243
APIM_CLIENT_ID=
APIM_CLIENT_SECRET=
